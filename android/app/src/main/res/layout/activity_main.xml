<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/canvas_bg">

    <!-- PREVIEW AREA — left in landscape, top in portrait (set at runtime) -->
    <FrameLayout
        android:id="@+id/previewArea"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@color/canvas_bg">

        <com.easycode.easyframe.ZoomableImageView
            android:id="@+id/previewImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="30dp"
            android:contentDescription="Превью" />

        <com.easycode.easyframe.EyedropperOverlay
            android:id="@+id/eyedropperOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="30dp"
            android:visibility="gone" />

        <!-- Empty state: shown until a photo is loaded -->
        <LinearLayout
            android:id="@+id/emptyStateView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="30dp"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:background="@drawable/bg_empty_state"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_download"
                android:contentDescription="Загрузить"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Загрузить"
                android:textSize="13sp"
                android:textColor="@color/tMid"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- Dimensions status bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_gravity="bottom"
            android:background="@color/statusbar_bg"
            android:paddingHorizontal="14dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/dimensionsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Фото не загружено"
                android:textSize="11sp"
                android:textColor="@color/tLo"
                android:fontFamily="monospace" />
        </LinearLayout>

    </FrameLayout>

    <!-- PANEL — right in landscape, bottom in portrait (set at runtime) -->
    <LinearLayout
        android:id="@+id/panelArea"
        android:layout_width="286dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/panel_bg"
        android:padding="14dp">

        <!-- Upload button — top of panel, above all controls -->
        <Button
            android:id="@+id/loadButton"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Загрузить"
            android:textSize="12sp"
            android:textColor="@color/tMid"
            android:background="@drawable/bg_auto_pill"
            android:paddingHorizontal="14dp"
            android:paddingVertical="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:stateListAnimator="@null"
            android:layout_marginBottom="12dp" />

        <!-- Scrollable controls -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Header: "Рамка" + rotate -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Рамка"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/tHi" />

                    <Button
                        android:id="@+id/btnRotate"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="↻"
                        android:textSize="17sp"
                        android:textColor="@color/tMid"
                        android:background="@drawable/bg_tool_circle"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingHorizontal="0dp"
                        android:paddingVertical="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:stateListAnimator="@null"
                        android:visibility="gone" />

                </LinearLayout>

                <!-- Толщина (секция заголовок) -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ТОЛЩИНА"
                    android:textSize="10sp"
                    android:textColor="@color/tLo"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp" />

                <!-- 2D pad: X = по бокам, Y = верх/низ; magnetic diagonal -->
                <com.easycode.easyframe.BorderPadView
                    android:id="@+id/borderPad"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/border_pad_height"
                    android:layout_marginBottom="10dp" />

                <!-- Numeric fields: по бокам / верх-низ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="↔ по бокам"
                            android:textSize="10sp"
                            android:textColor="@color/tLo"
                            android:fontFamily="monospace"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/fieldSides"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_input_field"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="12dp"
                            android:text="30"
                            android:textSize="16sp"
                            android:textColor="@color/tHi"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:inputType="number"
                            android:maxLength="4"
                            android:imeOptions="actionDone"
                            android:importantForAutofill="no" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="↕ верх / низ"
                            android:textSize="10sp"
                            android:textColor="@color/tLo"
                            android:fontFamily="monospace"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/fieldTopBottom"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_input_field"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="12dp"
                            android:text="30"
                            android:textSize="16sp"
                            android:textColor="@color/tHi"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:inputType="number"
                            android:maxLength="4"
                            android:imeOptions="actionDone"
                            android:importantForAutofill="no" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Hairline divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/hairline"
                    android:layout_marginBottom="12dp" />

                <!-- Цвет (секция заголовок) -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ЦВЕТ"
                    android:textSize="10sp"
                    android:textColor="@color/tLo"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp" />

                <!-- Active swatch + editable hex -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="10dp"
                    android:layout_marginBottom="12dp">

                    <View
                        android:id="@+id/activeSwatch"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_swatch_selected" />

                    <EditText
                        android:id="@+id/hexInput"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null"
                        android:gravity="center_vertical"
                        android:text="#FAFAFA"
                        android:hint="#RRGGBB"
                        android:textSize="14sp"
                        android:textColor="@color/tHi"
                        android:textColorHint="@color/tLo"
                        android:fontFamily="monospace"
                        android:inputType="textCapCharacters"
                        android:maxLength="7"
                        android:imeOptions="actionDone"
                        android:importantForAutofill="no" />

                </LinearLayout>

                <!-- Tool row: wand (auto) + pipette + wheel -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <!-- Auto (magic wand) -->
                    <Button
                        android:id="@+id/btnAuto"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_tool_circle"
                        android:foreground="@drawable/ic_wand"
                        android:foregroundGravity="center"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:stateListAnimator="@null"
                        android:layout_marginEnd="8dp" />

                    <!-- Pipette -->
                    <Button
                        android:id="@+id/btnEyedropper"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_tool_circle"
                        android:foreground="@drawable/ic_pipette"
                        android:foregroundGravity="center"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:stateListAnimator="@null"
                        android:layout_marginEnd="8dp" />

                    <!-- Color wheel (ring-gradient, filled programmatically) -->
                    <Button
                        android:id="@+id/btnColorWheel"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text=""
                        android:background="@drawable/bg_tool_circle"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingHorizontal="0dp"
                        android:paddingVertical="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:stateListAnimator="@null" />

                </LinearLayout>

                <!-- Active mode label -->
                <TextView
                    android:id="@+id/modeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="11sp"
                    android:textColor="@color/tMid"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="12dp" />

                <!-- Opacity -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="прозрачность"
                        android:textSize="11sp"
                        android:textColor="@color/tMid"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/opacityValueText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="100%"
                        android:textSize="11sp"
                        android:textColor="@color/tMid"
                        android:fontFamily="monospace" />

                </LinearLayout>

                <com.easycode.easyframe.OpacitySliderView
                    android:id="@+id/opacitySlider"
                    android:layout_width="match_parent"
                    android:layout_height="28dp"
                    android:layout_marginBottom="12dp" />

        <!-- Dropper card: shown when eyedropper is active (replaces swatches) -->
        <LinearLayout
            android:id="@+id/dropperCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp"
            android:background="@drawable/bg_dropper_card"
            android:visibility="gone"
            android:layout_marginBottom="10dp">

            <View
                android:id="@+id/dropperColorSwatch"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_dropper_swatch" />

            <TextView
                android:id="@+id/dropperHexText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="#------"
                android:textSize="14sp"
                android:textColor="@color/tHi"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:layout_marginStart="10dp" />

            <Button
                android:id="@+id/btnDropperConfirm"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Взять"
                android:textSize="13sp"
                android:textColor="#101012"
                android:background="@drawable/bg_save_button"
                android:paddingHorizontal="16dp"
                android:paddingVertical="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:stateListAnimator="@null" />

        </LinearLayout>

        <!-- Swatches row: 34dp circles -->
        <LinearLayout
            android:id="@+id/swatchesRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <!-- Selected/custom color swatch (34dp circle, dynamic color) -->
            <FrameLayout
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginEnd="6dp">
                <!-- Double ring (outer ring) -->
                <View
                    android:id="@+id/swatchSelectedRing"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_link_unlinked"
                    android:visibility="visible" />
                <!-- Inner circle with 3dp inset to show ring gap -->
                <View
                    android:id="@+id/swatchSelected"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_swatch_selected" />
            </FrameLayout>

            <!-- White swatch -->
            <FrameLayout
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginEnd="6dp">
                <View
                    android:id="@+id/swatchWhiteRing"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_link_unlinked"
                    android:visibility="invisible" />
                <View
                    android:id="@+id/swatchWhite"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_link_linked" />
            </FrameLayout>

            <!-- Dark swatch -->
            <FrameLayout
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginEnd="6dp">
                <View
                    android:id="@+id/swatchDarkRing"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_link_unlinked"
                    android:visibility="invisible" />
                <View
                    android:id="@+id/swatchDark"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_swatch_selected" />
            </FrameLayout>

            <!-- Gray swatch -->
            <FrameLayout
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginEnd="6dp">
                <View
                    android:id="@+id/swatchGrayRing"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_link_unlinked"
                    android:visibility="invisible" />
                <View
                    android:id="@+id/swatchGray"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_swatch_selected" />
            </FrameLayout>

            <!-- Warm swatch -->
            <FrameLayout
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginEnd="6dp">
                <View
                    android:id="@+id/swatchWarmRing"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_link_unlinked"
                    android:visibility="invisible" />
                <View
                    android:id="@+id/swatchWarm"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_swatch_selected" />
            </FrameLayout>

            <!-- Plus swatch (open color picker) -->
            <View
                android:id="@+id/swatchPlus"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_swatch_plus" />

        </LinearLayout>

                <!-- Donate link (opens external page; no permission needed) -->
                <TextView
                    android:id="@+id/donateButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="♥ Поддержать проект"
                    android:textSize="12sp"
                    android:textColor="@color/tMid"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:paddingVertical="12dp"
                    android:layout_marginTop="4dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>
        </ScrollView>

        <!-- Bottom action bar: Save (Load joins it in portrait, 50/50) -->
        <LinearLayout
            android:id="@+id/bottomBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/saveButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Сохранить"
                android:textSize="14sp"
                android:textColor="@color/canvas_bg"
                android:textStyle="bold"
                android:background="@drawable/bg_save_button"
                android:enabled="false"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:stateListAnimator="@null" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
