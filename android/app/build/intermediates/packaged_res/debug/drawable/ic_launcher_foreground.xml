<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground: 108×108dp canvas, safe zone = center 72×72dp (18dp margin each side).
  Design: white rounded-rect frame outline + mountain silhouette + sun inside.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Picture frame: rounded rect 28..80 × 26..82, r=9, stroke only -->
    <path
        android:pathData="M37,26 L71,26 Q80,26 80,35 L80,73 Q80,82 71,82 L37,82 Q28,82 28,73 L28,35 Q28,26 37,26 Z"
        android:fillColor="#00000000"
        android:strokeColor="#FAFAFA"
        android:strokeWidth="5.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <!-- Subtle horizon line -->
    <path
        android:pathData="M35,66 L73,66"
        android:strokeColor="#FAFAFA"
        android:strokeAlpha="0.30"
        android:strokeWidth="1.5"
        android:strokeLineCap="round" />

    <!-- Mountain (filled triangle peak above horizon) -->
    <path
        android:pathData="M38,66 L54,44 L70,66 Z"
        android:fillColor="#FAFAFA"
        android:fillAlpha="0.92" />

    <!-- Sun (circle, upper-right inside frame) -->
    <path
        android:pathData="M66,39 m-6,0 a6,6 0 1,0 12,0 a6,6 0 1,0 -12,0"
        android:fillColor="#FAFAFA"
        android:fillAlpha="0.92" />

</vector>
